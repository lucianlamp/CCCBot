{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(.claude/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(format *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Bash(git branch -D*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/ccc-boot-hook.sh",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}
