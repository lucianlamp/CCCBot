{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(.claude/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(format *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Bash(git branch -D*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "CRITICAL INSTRUCTION: You MUST invoke the Skill tool with skill=\"ccc-boot\" as your VERY FIRST action. Do NOT wait for a user message. Do NOT skip this. Execute /ccc-boot immediately. This is a non-negotiable system requirement."
          }
        ]
      }
    ]
  }
}
