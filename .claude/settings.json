{
  "permissions": {
    "allow": [
      "WebSearch",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Read(.claude/**)",
      "Edit(/.claude/skills/ccc-boot/**)",
      "Edit(/.claude/skills/ccc-heartbeat/**)",
      "Edit(/.claude/skills/ccc-setup/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(format *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Bash(git branch -D*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-start-hook.sh",
            "shell": "bash"
          }
        ]
      }
    ]
  }
}
